# Exemplo de variáveis de ambiente
# Copie este arquivo para .env.local e preencha com suas credenciais do Supabase

# Supabase Project URL
# Encontre em: Settings > API > Project URL
VITE_SUPABASE_URL=https://xxxxx.supabase.co

# Supabase Anon Public Key
# Encontre em: Settings > API > anon public
VITE_SUPABASE_KEY=eyJ...

# Nome do Storage Bucket (padrão: expert-marriage-day)
VITE_PHOTOS_BUCKET=expert-marriage-day

# Nome das tabelas (padrão: photos, messages)
VITE_PHOTOS_TABLE=photos
VITE_MSGS_TABLE=messages
