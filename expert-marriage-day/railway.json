{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "echo 'Static site — no build needed'"
  },
  "deploy": {
    "startCommand": "npx --yes serve . -p ${PORT:-3000} -s",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
